# Copy to /home/ubuntu/.env (or next to docker-compose) and fill values.
# docker compose --env-file .env -f docker-compose.ec2.yml up -d

# --- Browser origins for CORS (comma-separated). Use your real HTTPS domain.
ALLOWED_ORIGINS=https://privora-app.com,https://www.privora-app.com

# --- EC2 public IPv4 (coturn external-ip + TURN URL host must match what clients reach)
TURN_PUBLIC_IP=51.21.219.239

# --- Same secret for FastAPI /api/rtc-config (ephemeral creds) and coturn static-auth-secret
TURN_SHARED_SECRET=replace-with-a-long-random-string

# --- ICE URL the browser uses for TURN (must be reachable from the internet)
TURN_SERVER_URLS=turn:51.21.219.239:3478

# --- Optional STUN (defaults in compose if omitted)
STUN_SERVER_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# --- Optional credential lifetime (seconds)
# TURN_TTL_SECONDS=3600

# AWS security group: allow TCP 3478, UDP 3478, UDP 49160-49200 inbound to this instance.
