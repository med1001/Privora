# Copy to .env in this folder (same directory as requirements.txt):
#   copy .env.example .env
#
# Firebase Admin SDK JSON (path relative to this server/ directory)
FIREBASE_ADMIN_CREDENTIALS_JSON=./src/firebase_credentials.json

# CORS: browser origins allowed to call the API (comma-separated, no trailing slash)
# Include 127.0.0.1 for Docker Desktop on Windows (localhost→IPv6 quirks). Add http://YOUR_LAN_IP:3000 if you open the app by IP.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Optional WebRTC ICE (defaults are fine for most local tests) ---
# STUN_SERVER_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# --- Local TURN (docker-compose.local.yml includes coturn) — must match coturn static-auth-secret ---
# Same secret as in docker-compose default: privora-local-dev-turn-secret-only
TURN_SERVER_URLS=turn:127.0.0.1:3478
TURN_SHARED_SECRET=privora-local-dev-turn-secret-only
